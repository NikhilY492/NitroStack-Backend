{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://shift-left-finops/state.schema.json",
  "title": "AgentState",
  "description": "Shared state object that flows through all six Agent Runtime stages",
  "type": "object",
  "required": ["sessionId", "requirements", "architecture", "pricing", "policyResults", "reasoning", "approvalStatus", "terraform"],
  "properties": {
    "sessionId": { "type": "string", "format": "uuid" },
    "requirements": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/Requirements" }]
    },
    "architecture": {
      "type": "object",
      "properties": {
        "candidates": { "type": "array", "items": { "$ref": "#/definitions/ArchitectureCandidate" } },
        "recommended": { "oneOf": [{ "type": "null" }, { "type": "string" }] }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/PricingBreakdown" }
    },
    "policyResults": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "$ref": "#/definitions/PolicyCheck" } }
    },
    "reasoning": { "$ref": "#/definitions/ReasoningState" },
    "approvalStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
    "terraform": {
      "oneOf": [{ "type": "null" }, {
        "type": "object",
        "properties": {
          "hcl": { "type": "string" },
          "candidateId": { "type": "string" }
        }
      }]
    }
  },
  "definitions": {
    "Requirements": {
      "type": "object",
      "required": ["description", "expectedUsers", "monthlyBudget", "slaTarget", "environment", "classification"],
      "properties": {
        "description": { "type": "string" },
        "expectedUsers": { "type": "number", "minimum": 1 },
        "monthlyBudget": { "type": "number", "minimum": 0 },
        "slaTarget": { "type": "string" },
        "environment": { "type": "string", "enum": ["prod", "dev", "staging"] },
        "classification": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ArchitectureCandidate": {
      "type": "object",
      "required": ["id", "label", "compute", "database", "cache", "scaling", "instanceType"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "compute": { "type": "string", "enum": ["ec2", "ecs_fargate", "lambda"] },
        "database": { "type": "string", "enum": ["postgresql", "dynamodb"] },
        "cache": { "type": "boolean" },
        "scaling": { "type": "string", "enum": ["auto", "fixed"] },
        "instanceType": { "type": "string" },
        "monthlyCost": { "type": "number" }
      }
    },
    "PricingBreakdown": {
      "type": "object",
      "required": ["monthlyCost", "compute", "storage", "networkEgress", "cache", "other"],
      "properties": {
        "monthlyCost": { "type": "number" },
        "compute": { "type": "number" },
        "storage": { "type": "number" },
        "networkEgress": { "type": "number" },
        "cache": { "type": "number" },
        "other": { "type": "number" }
      }
    },
    "PolicyCheck": {
      "type": "object",
      "required": ["ruleId", "label", "passed"],
      "properties": {
        "ruleId": { "type": "string" },
        "label": { "type": "string" },
        "passed": { "type": "boolean" },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "reason": { "type": "string" }
      }
    },
    "ReasoningState": {
      "type": "object",
      "properties": {
        "planner": { "type": "array", "items": { "type": "string" } },
        "requirements": { "type": "array", "items": { "type": "string" } },
        "architect": { "type": "array", "items": { "type": "string" } },
        "cost": { "type": "array", "items": { "type": "string" } },
        "policy": { "type": "array", "items": { "type": "string" } },
        "coordinator": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
